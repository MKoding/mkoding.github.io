---
import { Icon } from 'astro-icon/components';

interface Props {
    title: string;
    description: string;
    icon?: string;
    direction?: 'right' | 'left';
    freezePoint?: number;
}

const { title, description, icon, direction = 'right', freezePoint = 0.6 } = Astro.props;
---

<div class={`card scroll-parallax parallax-${direction}`} data-parallax-freeze-point={freezePoint}>
    {
        icon ? (
            <h3 class="mb-4 flex items-center gap-3">
                <Icon name={icon} class="h-6 w-6 flex-shrink-0 text-[var(--color-accent)]" />
                <span>{title}</span>
            </h3>
        ) : (
            <h3 class="mb-2">{title}</h3>
        )
    }
    <p class="text-base leading-relaxed">{description}</p>
</div>
