---
interface Props {
    title: string;
    description: string;
    icon?: string;
    direction?: 'right' | 'left';
    freezePoint?: number;
}

const { title, description, icon, direction = 'right', freezePoint = 0.6 } = Astro.props;
---

<div
    class={`card scroll-parallax parallax-${direction}`}
    data-parallax-freeze-point={freezePoint}
>
    {
        icon ? (
            <h3 class="mb-4 flex items-center gap-3">
                <div class="service-icon" data-icon={icon} />
                <span>{title}</span>
            </h3>
        ) : (
            <h3 class="mb-2">{title}</h3>
        )
    }
    <p class="text-base leading-relaxed">{description}</p>
</div>
