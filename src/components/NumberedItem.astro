---
import { Icon } from 'astro-icon/components';

interface Props {
    title: string;
    description: string;
    icon?: string;
    number?: number | string;
    freezePoint?: number;
    direction?: 'right' | 'left';
}

const { title, description, icon, number, freezePoint = 0.6, direction = 'right' } = Astro.props;
const hasIcon = Boolean(icon);
---

<div
    class={`numbered-item scroll-parallax parallax-${direction}${hasIcon ? ' md:items-center' : ''}`}
    data-parallax-freeze-point={freezePoint}
>
    <div class={`numbered-item-icon${hasIcon ? ' md:p-0' : ''}`}>
        <div class={`numbered-item-circle${hasIcon ? ' md:h-12 md:w-12' : ''}`}>
            {
                hasIcon ? (
                    <Icon name={icon} class="h-7 w-7 md:h-8 md:w-8 text-[var(--color-accent)]" />
                ) : (
                    number
                )
            }
        </div>
    </div>
    <div class="numbered-item-content">
        <h3 class="numbered-item-title">{title}</h3>
        <p class="numbered-item-description">{description}</p>
    </div>
</div>
