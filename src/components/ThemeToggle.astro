<!-- Theme Toggle -->
<div class="fixed top-20 right-8 z-50">
    <button
        id="theme-toggle"
        class="p-2 rounded-full transition-all duration-200"
        aria-label="Toggle theme"
    >
        <svg id="sun-icon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="5"></circle>
            <rect x="11" y="1" width="2" height="4" rx="1"></rect>
            <rect x="11" y="19" width="2" height="4" rx="1"></rect>
            <rect x="1" y="11" width="4" height="2" rx="1"></rect>
            <rect x="19" y="11" width="4" height="2" rx="1"></rect>
            <rect
                x="3.515"
                y="3.515"
                width="2.828"
                height="2.828"
                rx="1"
                transform="rotate(45, 5, 5)"></rect>
            <rect
                x="17.657"
                y="17.657"
                width="2.828"
                height="2.828"
                rx="1"
                transform="rotate(45, 19, 19)"></rect>
            <rect
                x="17.657"
                y="3.515"
                width="2.828"
                height="2.828"
                rx="1"
                transform="rotate(-45, 19, 5)"></rect>
            <rect
                x="3.515"
                y="17.657"
                width="2.828"
                height="2.828"
                rx="1"
                transform="rotate(-45, 5, 19)"></rect>
        </svg>
        <svg id="moon-icon" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
    </button>
</div>
