---
const currentPath = Astro.url.pathname;

let currentPage: 'home' | 'about' | 'contact';

switch (true) {
    case currentPath.includes('sobre-nosotros'):
        currentPage = 'about';
        break;
    case currentPath.includes('contacto'):
        currentPage = 'contact';
        break;
    default:
        currentPage = 'home';
}
---

<!-- Navigation -->
<nav class="fixed top-0 left-0 right-0 z-40 backdrop-blur-md bg-[var(--color-bg)]/80">
    <div class="section-content py-2">
        <div class="flex items-center justify-between">
            <a href="/" class="flex items-center logo-hover">
                <img
                    src="/icons/mkoding.svg"
                    alt="Logo MKoding"
                    class="h-10 w-auto theme-switch-icon"
                />
            </a>

            <!-- Desktop Menu -->
            <div class="hidden md:flex items-center gap-8">
                <a
                    href="/"
                    class={`font-medium transition-all ${
                        currentPage === 'home'
                            ? 'text-[var(--color-accent-text)] hover:text-[var(--color-accent-text-hover)] hover:-translate-y-0.5'
                            : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:-translate-y-0.5'
                    }`}
                >
                    Inicio
                </a>
                <a
                    href="/sobre-nosotros"
                    class={`font-medium transition-all ${
                        currentPage === 'about'
                            ? 'text-[var(--color-accent-text)] hover:text-[var(--color-accent-text-hover)] hover:-translate-y-0.5'
                            : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:-translate-y-0.5'
                    }`}
                >
                    Sobre MKoding
                </a>
                <a
                    href="/contacto"
                    class={`font-medium transition-all ${
                        currentPage === 'contact'
                            ? 'text-[var(--color-accent-text)] hover:text-[var(--color-accent-text-hover)] hover:-translate-y-0.5'
                            : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:-translate-y-0.5'
                    }`}
                >
                    Contacto
                </a>
            </div>

            <!-- Mobile Menu Button -->
            <button
                id="mobile-menu-button"
                class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg transition-colors hover:bg-[var(--color-surface)]"
                aria-label="Abrir menú"
            >
                <img src="/icons/menu.svg" alt="Menú" class="w-8 h-8 theme-switch-icon" />
            </button>
        </div>
    </div>
</nav>

<!-- Mobile Menu Overlay -->
<div
    id="mobile-menu"
    class="fixed inset-0 z-50 md:hidden opacity-0 pointer-events-none transition-opacity duration-300"
>
    <!-- Backdrop -->
    <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

    <!-- Menu Panel -->
    <div
        class="absolute right-0 top-0 bottom-0 w-4/5 max-w-sm bg-[var(--color-bg)] shadow-2xl transform translate-x-full transition-transform duration-300"
        id="mobile-menu-panel"
    >
        <!-- Close Button -->
        <div class="flex justify-end p-4">
            <button
                id="mobile-menu-close"
                class="flex items-center justify-center w-10 h-10 rounded-lg transition-colors hover:bg-[var(--color-surface)]"
                aria-label="Cerrar menú"
            >
                <img src="/icons/close.svg" alt="Cerrar" class="w-8 h-8 theme-switch-icon" />
            </button>
        </div>

        <!-- Menu Links -->
        <nav class="flex flex-col items-end justify-center h-[calc(100%-5rem)] px-8 space-y-8">
            <a
                href="/"
                class={`mobile-menu-link text-2xl font-medium transition-all ${
                    currentPage === 'home'
                        ? 'text-[var(--color-accent-text)]'
                        : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text)]'
                }`}
            >
                Inicio
            </a>
            <a
                href="/sobre-nosotros"
                class={`mobile-menu-link text-2xl font-medium transition-all ${
                    currentPage === 'about'
                        ? 'text-[var(--color-accent-text)]'
                        : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text)]'
                }`}
            >
                Sobre MKoding
            </a>
            <a
                href="/contacto"
                class={`mobile-menu-link text-2xl font-medium transition-all ${
                    currentPage === 'contact'
                        ? 'text-[var(--color-accent-text)]'
                        : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text)]'
                }`}
            >
                Contacto
            </a>
        </nav>
    </div>
</div>

<script>
    const menuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuPanel = document.getElementById('mobile-menu-panel');
    const closeButton = document.getElementById('mobile-menu-close');
    const backdrop = document.getElementById('mobile-menu-backdrop');
    const menuLinks = document.querySelectorAll('.mobile-menu-link');

    function openMenu() {
        if (mobileMenu && menuPanel) {
            mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
            setTimeout(() => {
                menuPanel.classList.remove('translate-x-full');
            }, 10);
            document.body.style.overflow = 'hidden';
        }
    }

    function closeMenu() {
        if (mobileMenu && menuPanel) {
            menuPanel.classList.add('translate-x-full');
            setTimeout(() => {
                mobileMenu.classList.add('opacity-0', 'pointer-events-none');
                document.body.style.overflow = '';
            }, 300);
        }
    }

    menuButton?.addEventListener('click', openMenu);
    closeButton?.addEventListener('click', closeMenu);
    backdrop?.addEventListener('click', closeMenu);

    menuLinks.forEach((link) => {
        link.addEventListener('click', closeMenu);
    });
</script>
