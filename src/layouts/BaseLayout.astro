---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Footer from '../components/Footer.astro';

const {
    pageTitle = 'MKoding — Ingeniería de software con criterio',
    pageDescription = 'Ingeniería de software y dirección tecnológica con enfoque responsable y mantenible.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og-image-white.png', Astro.site);
const darkThemeColor = '#0f0f0f';
const lightThemeColor = '#ffffff';

const organizationLd = {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'MKoding',
    url: String(Astro.site),
    logo: String(ogImageURL),
    sameAs: [
        'https://www.linkedin.com/in/mikel-romano-ullate-353261112',
        'https://github.com/mkoding',
    ],
};
---

<!doctype html>
<html lang="es" data-theme="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
        <meta name="color-scheme" content="dark light" />
        <meta name="theme-color" content={darkThemeColor} />
        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />
        <link rel="canonical" href={canonicalURL} />

        <meta property="og:type" content="website" />
        <meta property="og:site_name" content="MKoding" />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:image" content={ogImageURL} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={pageDescription} />
        <meta name="twitter:image" content={ogImageURL} />

        <script is:inline>
            const theme = localStorage.getItem('theme') || 'dark';
            document.documentElement.setAttribute('data-theme', theme);

            const themeColorMeta = document.querySelector('meta[name="theme-color"]');
            if (themeColorMeta) {
                themeColorMeta.setAttribute('content', theme === 'dark' ? '#0f0f0f' : '#ffffff');
            }
        </script>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto:wght@700&display=swap"
            media="print"
            onload="this.media='all';this.onload=null;"
        />
        <noscript>
            <link
                rel="stylesheet"
                href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto:wght@700&display=swap"
            />
        </noscript>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    </head>

    <body class="antialiased transition-colors duration-300">
        <Navigation />
        <ThemeToggle />

        <main class="pt-14">
            <slot />
        </main>

        <Footer />

        <script>
            import { initializeThemeSystem } from '../scripts/themeSystem.ts';
            import { initializeParallaxSystem } from '../scripts/parallaxSystem.ts';

            initializeThemeSystem();
            initializeParallaxSystem();
        </script>
    </body>
</html>
