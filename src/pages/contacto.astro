---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SplitHeading from '../components/SplitHeading.astro';
---

<BaseLayout
    pageTitle="Contacto — MKoding"
    pageDescription="Ponte en contacto con MKoding. Cuéntanos sobre tu proyecto, tus desafíos y cómo podemos ayudarte."
>
    <Hero
        title="Hablemos de tu proyecto"
        subtitle="Cuéntanos sobre tus desafíos tecnológicos. Sin compromisos, sin presión."
    />

    <!-- FORMULARIO DE CONTACTO -->
    <section class="pb-24 md:pb-32">
        <div class="section-content">
            <div class="max-w-2xl mx-auto">
                <form id="contact-form" class="space-y-8">
                    <!-- Nombre -->
                    <div>
                        <label for="nombre" class="block text-sm font-medium mb-2"> Nombre </label>
                        <input
                            type="text"
                            id="nombre"
                            name="nombre"
                            required
                            class="form-input"
                            placeholder="Tu nombre"
                        />
                    </div>

                    <!-- Email -->
                    <div>
                        <label for="email" class="block text-sm font-medium mb-2"> Email </label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            class="form-input"
                            placeholder="tu@email.com"
                        />
                    </div>

                    <!-- Empresa -->
                    <div>
                        <label for="empresa" class="block text-sm font-medium mb-2">
                            Empresa (opcional)
                        </label>
                        <input
                            type="text"
                            id="empresa"
                            name="empresa"
                            class="form-input"
                            placeholder="Nombre de tu empresa"
                        />
                    </div>

                    <!-- Tipo de proyecto -->
                    <div>
                        <label for="tipo" class="block text-sm font-medium mb-2">
                            ¿De qué trata tu proyecto?
                        </label>
                        <select id="tipo" name="tipo" required class="form-select">
                            <option value="">Selecciona una opción</option>
                            <option value="Desarrollo web">Desarrollo web</option>
                            <option value="E-commerce">E-commerce</option>
                            <option value="Aplicación móvil">Aplicación móvil</option>
                            <option value="Sistemas internos">Sistemas internos</option>
                            <option value="Dirección técnica">Dirección técnica</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>

                    <!-- Mensaje -->
                    <div>
                        <label for="mensaje" class="block text-sm font-medium mb-2">
                            Cuéntanos sobre tu proyecto
                        </label>
                        <textarea
                            id="mensaje"
                            name="mensaje"
                            required
                            rows="6"
                            class="form-textarea"
                            placeholder="Describe brevemente tu proyecto, desafíos y qué esperas conseguir..."
                        ></textarea>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="btn text-white font-bold rounded-lg w-full">
                        Enviar mensaje
                    </button>
                </form>
            </div>
        </div>
    </section>

    <!-- OTRAS FORMAS DE CONTACTO -->
    <section class="pb-24 md:pb-32">
        <div class="section-content">
            <div class="max-w-2xl mx-auto">
                <div>
                    <div class="flex justify-center mb-12 md:mb-18">
                        <SplitHeading
                            title="Otras formas de contactarnos"
                            splitStart={0.85}
                            splitEnd={0.65}
                        />
                    </div>
                    <div class="flex flex-wrap gap-4 justify-center">
                        <!-- Teléfono -->
                        <a href="tel:+34611696286" title="Teléfono" class="contact-button">
                            <img src="/icons/phone.svg" alt="Teléfono" class="contact-icon" />
                        </a>

                        <!-- WhatsApp -->
                        <a
                            href="https://wa.me/34611696286"
                            target="_blank"
                            title="WhatsApp"
                            class="contact-button"
                        >
                            <img src="/icons/whatsapp.svg" alt="WhatsApp" class="contact-icon" />
                        </a>

                        <!-- LinkedIn -->
                        <a
                            href="https://www.linkedin.com/in/mikel-romano-ullate-353261112"
                            target="_blank"
                            title="LinkedIn"
                            class="contact-button"
                        >
                            <img src="/icons/linkedin.svg" alt="LinkedIn" class="contact-icon" />
                        </a>

                        <!-- GitHub -->
                        <a
                            href="https://github.com/mkoding"
                            target="_blank"
                            title="GitHub"
                            class="contact-button"
                        >
                            <img src="/icons/github.svg" alt="GitHub" class="contact-icon" />
                        </a>

                        <!-- Email -->
                        <a
                            href="mailto:contacto@mkodingsoft.com"
                            title="Email"
                            class="contact-button"
                        >
                            <img src="/icons/email.svg" alt="Email" class="contact-icon" />
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        const form = document.getElementById('contact-form');

        if (form) {
            form.addEventListener('submit', (e) => {
                e.preventDefault();

                const nombre = (document.getElementById('nombre') as HTMLInputElement)?.value ?? '';
                const email = (document.getElementById('email') as HTMLInputElement)?.value ?? '';
                const empresa =
                    (document.getElementById('empresa') as HTMLInputElement)?.value ?? '';
                const tipo = (document.getElementById('tipo') as HTMLSelectElement)?.value ?? '';
                const mensaje =
                    (document.getElementById('mensaje') as HTMLTextAreaElement)?.value ?? '';

                if (!nombre.trim() || !email.trim() || !tipo.trim() || !mensaje.trim()) {
                    alert('Por favor, completa todos los campos obligatorios.');
                    return;
                }

                const asunto = `Nuevo contacto de ${nombre} - ${tipo}`;
                const cuerpo = `
                    Nombre: ${nombre}
                    Email: ${email}
                    Empresa: ${empresa.trim() || 'No especificada'}
                    Tipo de proyecto: ${tipo}

                    Mensaje:
                    ${mensaje}
                `.trim();

                const mailtoLink = `mailto:contacto@mkodingsoft.com?subject=${encodeURIComponent(asunto)}&body=${encodeURIComponent(cuerpo)}`;
                window.location.href = mailtoLink;
            });
        }
    </script>
</BaseLayout>
